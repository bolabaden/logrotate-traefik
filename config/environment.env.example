# Example environment configuration for logrotate-traefik
# Copy this file to .env and customize as needed

# =============================================================================
# Log Configuration
# =============================================================================

# Directory where Traefik stores its logs (must be accessible to the container)
TRAEFIK_LOG_DIR=/var/log/traefik

# Name of the main Traefik log file
TRAEFIK_LOG_FILENAME=traefik.log

# Logging level for the logrotate service itself
# Options: debug, verbose, info, warning, error
LOG_LEVEL=info

# =============================================================================
# Logrotate Configuration
# =============================================================================

# How often to check for rotation (in seconds)
# Minimum: 30, Recommended: 300 (5 minutes)
LOGROTATE_LOOP_SLEEP=300

# Maximum size of a log file before rotation
# Examples: 1M, 10M, 100M, 1G
LOGROTATE_MAXSIZE=10M

# Number of rotated log files to keep
# Older files will be deleted automatically
LOGROTATE_MAXCOUNT=20

# Rotation frequency (when size limit is not reached)
# Options: hourly, daily, weekly, monthly
LOGROTATE_ROTATE_FREQ=hourly

# Maximum total size of log directory in MB before cleanup
# When exceeded, oldest compressed files will be removed
LOGROTATE_MAXDIR_MB=50

# Number of compressed (.gz) files to keep during cleanup
# Only applies when directory size exceeds LOGROTATE_MAXDIR_MB
LOGROTATE_KEEP_GZ=10

# Path to logrotate state file (tracks rotation history)
LOGROTATE_STATE_FILE=/var/lib/logrotate.status

# =============================================================================
# Monitoring Configuration
# =============================================================================

# HTTP status codes to display in real-time monitoring
# Examples:
#   100-999          (all status codes)
#   200,201,204      (specific success codes)
#   400-499          (client errors only)
#   500-599          (server errors only)
#   200,300-399,404  (mixed ranges and specific codes)
STATUS_CODES=100-999

# =============================================================================
# System Configuration
# =============================================================================

# Timezone for log timestamps
TZ=America/Chicago

# =============================================================================
# Advanced Configuration
# =============================================================================

# Custom logrotate configuration (if you want to override defaults)
# CUSTOM_LOGROTATE_CONFIG=/path/to/custom/logrotate.conf

# Enable/disable DNS resolution for client IPs in monitoring
# Set to 'false' to improve performance if you don't need hostnames
# RESOLVE_CLIENT_IPS=true

# Custom color scheme for status code display
# CUSTOM_COLORS=true
